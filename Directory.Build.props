<Project>
  <PropertyGroup>
    <!-- Folder containing SpaceEngineers.exe.
         Fill the path between the tags to override; leave empty to use the
         platform-specific auto-detection in ClientPlugin.csproj. -->
    <Bin64></Bin64>

    <!-- Plugin version -->
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>
</Project>
